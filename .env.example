# Avalanche RPC URL (e.g. from Core Wallet or public node)
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Private key for deployment (never commit your real one!)
PRIVATE_KEY=your_private_key_here

# Optional: Etherscan/Snowtrace API key for contract verification
SNOWTRACE_API_KEY=your_api_key_here

# Optional: Wallet address to receive payments
PAYMENT_RECEIVER=0xYourWalletAddress
